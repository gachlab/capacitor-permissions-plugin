{
  "name": "@gachlab/capacitor-permissions",
  "version": "3.1.1",
  "description": "Capacitor plugin to monitor device permission states (geolocation, notifications) across Android, iOS, and Web.",
  "type": "module",
  "main": "dist/plugin.cjs.js",
  "module": "dist/esm/index.js",
  "types": "dist/esm/index.d.ts",
  "unpkg": "dist/plugin.js",
  "files": [
    "android/src/main/",
    "android/build.gradle",
    "dist/",
    "ios/Plugin/",
    "GachlabCapacitorPermissions.podspec",
    "Package.swift"
  ],
  "author": "Guillermo Carrillo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gachlab/capacitor-permissions-plugin.git"
  },
  "bugs": {
    "url": "https://github.com/gachlab/capacitor-permissions-plugin/issues"
  },
  "keywords": [
    "capacitor",
    "plugin",
    "native",
    "permissions",
    "geolocation",
    "notifications",
    "monitor",
    "android",
    "ios"
  ],
  "scripts": {
    "verify": "npm run verify:ios && npm run verify:android && npm run verify:web",
    "verify:ios": "xcodebuild -scheme GachlabCapacitorPermissions -destination generic/platform=iOS",
    "verify:android": "cd android && ./gradlew clean build test && cd ..",
    "verify:web": "npm run build",
    "lint": "eslint . && npm run prettier -- --check && npm run swiftlint -- lint",
    "fmt": "eslint . --fix && npm run prettier -- --write && npm run swiftlint -- --fix --format",
    "prettier": "prettier \"**/*.{css,html,ts,js,java}\" --plugin=prettier-plugin-java",
    "swiftlint": "node-swiftlint",
    "build": "npm run clean && vite build",
    "clean": "rimraf ./dist",
    "watch": "vite build --watch",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@capacitor/android": "^8.0.1",
    "@capacitor/core": "^8.0.1",
    "@capacitor/ios": "^8.0.1",
    "@ionic/prettier-config": "^4.0.0",
    "@ionic/swiftlint-config": "^2.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "eslint": "^9.39.2",
    "prettier": "^3.8.0",
    "prettier-plugin-java": "^2.8.1",
    "rimraf": "^6.1.2",
    "swiftlint": "^2.0.0",
    "typescript": "^6.0.0",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.4.0",
    "vitest": "^3.2.1"
  },
  "peerDependencies": {
    "@capacitor/core": "^8.0.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "prettier": "@ionic/prettier-config",
  "swiftlint": "@ionic/swiftlint-config",
  "capacitor": {
    "ios": {
      "src": "ios"
    },
    "android": {
      "src": "android"
    }
  }
}
